{% comment %}
  Generic CV entry renderer
  Supports:
  - Academic Positions
  - Education
  - Publications
  - Research Stays
  - Skills
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item">
      <div class="row">

        <!-- DATE COLUMN -->
        <div class="col-xs-2 col-sm-2 col-md-2 text-center date-column">

          {% capture start_date %}
            {% if entry.start_date %}{{ entry.start_date }}{% endif %}
          {% endcapture %}

          {% capture end_date %}
            {% if entry.end_date %}{{ entry.end_date }}{% endif %}
          {% endcapture %}

          {% if start_date != '' %}
            {% assign startDate = start_date | split: '-' | first %}
            {% assign endDate = end_date | split: '-' | first | default: 'Present' %}
            {% assign date = startDate | append: ' - ' | append: endDate %}
          {% elsif entry.releaseDate %}
            {% assign date = entry.releaseDate %}
          {% else %}
            {% assign date = '' %}
          {% endif %}

          <table class="table-cv">
            <tbody>

              {% if date != '' %}
              <tr>
                <td>
                  <span class="badge font-weight-bold danger-color-dark text-uppercase align-middle"
                        style="min-width: 75px">
                    {{ date }}
                  </span>
                </td>
              </tr>
              {% endif %}

              {% if entry.location %}
              <tr>
                <td>
                  <p class="location">
                    <i class="fa-solid fa-location-dot iconlocation"></i>
                    {{ entry.location }}
                  </p>
                </td>
              </tr>
              {% endif %}

            </tbody>
          </table>
        </div>

        <!-- CONTENT COLUMN -->
        <div class="col-xs-10 col-sm-10 col-md-10 mt-2 mt-md-0">

          <!-- TITLE -->
          {% if entry.position %}
            <h6 class="title font-weight-bold ml-1 ml-md-4">
              {{ entry.position }}
            </h6>

          {% elsif entry.studyType %}
            <h6 class="title font-weight-bold ml-1 ml-md-4">
              {{ entry.studyType }}{% if entry.area %} in {{ entry.area }}{% endif %}
            </h6>

          {% elsif entry.title %}
            <h6 class="title font-weight-bold ml-1 ml-md-4">
              <i>{{ entry.title }}</i>
            </h6>

          {% elsif entry.name %}
            <h6 class="title font-weight-bold ml-1 ml-md-4">
              {{ entry.name }}
            </h6>
          {% endif %}

          <!-- INSTITUTION -->
          {% if entry.institution %}
            <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem">
              {{ entry.institution }}
            </h6>
          {% endif %}

          <!-- AUTHORS -->
          {% if entry.authors %}
            <h6 class="ml-1 ml-md-4"
                style="font-size: 0.9rem; font-style: italic">
              {{ entry.authors | join: ", " }}
            </h6>
          {% endif %}

          <!-- PUBLISHER -->
          {% if entry.publisher %}
            <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem">
              {{ entry.publisher }}
            </h6>
          {% endif %}

          <!-- THESIS -->
          {% if entry.thesis %}
            <p class="ml-1 ml-md-4" style="font-style: italic">
              Thesis: {{ entry.thesis }}
            </p>
          {% endif %}

          <!-- SUPERVISOR -->
          {% if entry.supervisor %}
            <p class="ml-1 ml-md-4">
              Supervisor: {{ entry.supervisor }}
            </p>
          {% endif %}

          <!-- HOST -->
          {% if entry.host %}
            <p class="ml-1 ml-md-4">
              Host: {{ entry.host }}
            </p>
          {% endif %}

          <!-- SUMMARY -->
          {% if entry.summary %}
            <p class="ml-1 ml-md-4">
              {{ entry.summary }}
            </p>
          {% endif %}

          <!-- KEYWORDS -->
          {% if entry.keywords %}
            <ul class="items">
              {% for item in entry.keywords %}
                <li>
                  <span class="item">{{ item }}</span>
                </li>
              {% endfor %}
            </ul>
          {% endif %}

        </div>
      </div>
    </li>
  {% endfor %}
</ul>